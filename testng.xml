<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SauceDemoSuite"
       parallel="tests"
       thread-count="2">

    <listeners>
        <listener class-name="utils.ExtentListener"/>
    </listeners>

    <test name="ChromeTest">

        <parameter name="browser"
                   value="chrome"/>

        <classes>
            <class name="tests.BuyProductTest"/>
        </classes>

    </test>

    <test name="FirefoxTest">

        <parameter name="browser"
                   value="firefox"/>

        <classes>
            <class name="tests.BuyProductTest2"/>
        </classes>

    </test>

</suite>